{
  "$schema": "https://turbo.build/schema.v1.json",
  "pipeline": {
    "prepare": {
      "dependsOn": ["^prepare"],
      "outputs": ["lib/**", "es/**", "dist/**", "typings/**"]
    },
    "test": {
      "dependsOn": ["^prepare"]
    },
    "test:watch": {
      "persistent": true
    },
    "test:update": {},
    "dev": {
      "dependsOn": ["^prepare"],
      "persistent": true
    },
    "lint": {},
    "typings": {},
    "check-types": {}
  }
}
