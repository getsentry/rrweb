{
  "name": "@sentry-internal/rrweb-worker",
  "version": "2.31.0",
  "description": "Worker for rrweb",
  "main": "dist/rrweb-worker.js",
  "module": "dist/rrweb-worker.mjs",
  "types": "typings/index.d.ts",
  "sideEffects": false,
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:old": "rollup --config",
    "typings": "tsc -p tsconfig.types.json",
    "prepare": "npm run typings && npm run build",
    "prepublish": "npm run typings && npm run build",
    "check-types": "tsc -noEmit",
    "test": "yarn jest",
    "lint": "yarn eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/rrweb.git"
  },
  "author": "Sentry",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/getsentry/rrweb/issues"
  },
  "dependencies": {
    "@sentry-internal/rrweb-snapshot": "2.31.0",
    "@sentry-internal/rrweb-types": "2.31.0"
  },
  "devDependencies": {
    "@types/css-font-loading-module": "0.0.7",
    "vite": "^5.2.8"
  },
  "engines": {
    "node": ">=12"
  }
}
